{
  "manifest_version": 3,
  "name": "Mr.Creative Bot",
  "version": "1.0.0",
  "description": "Automates Pomelli & Flow image generation — controlled from Mr.Creative dashboard",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://labs.google.com/pomelli/*",
    "https://labs.google/fx/tools/flow*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google.com/pomelli/*"],
      "js": ["lib/utils.js", "content/pomelli.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://labs.google/fx/tools/flow*"],
      "js": ["lib/utils.js", "content/flow.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Mr.Creative Bot"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
