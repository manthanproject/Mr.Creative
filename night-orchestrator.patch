diff --git a/templates/night_ops.html b/templates/night_ops.html
new file mode 100644
index 0000000..87c6b2b
--- /dev/null
+++ b/templates/night_ops.html
@@ -0,0 +1,350 @@
+{% extends "base.html" %}
+{% block title %}Night Ops — Mr.Creative{% endblock %}
+
+{% block content %}
+<div class="page-header">
+    <div class="page-header-actions">
+        <div>
+            <h1>🌙 Night Ops</h1>
+            <p>Overnight intelligence — trends, competitors, content plans</p>
+        </div>
+        <div class="header-btns">
+            <button class="btn btn-primary" id="btnStartCycle" onclick="startCycle()">
+                ▶ Run Night Cycle
+            </button>
+        </div>
+    </div>
+</div>
+
+<!-- Cycle Status Banner (hidden by default) -->
+<div id="cycleStatus" class="card animate-fade-up" style="display:none; margin-bottom:12px; border-left: 3px solid var(--accent);">
+    <div class="card-body" style="padding:16px;">
+        <div style="display:flex; align-items:center; gap:12px;">
+            <div id="cycleSpinner" class="spinner" style="width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;"></div>
+            <div style="flex:1;">
+                <div style="font-weight:600;" id="cycleAgent">Starting...</div>
+                <div style="font-size:0.85rem;color:var(--text-muted);" id="cycleMessage"></div>
+            </div>
+            <div style="font-weight:600;color:var(--accent);" id="cycleProgress">0%</div>
+        </div>
+        <div style="margin-top:10px;background:var(--bg-hover);border-radius:4px;height:4px;overflow:hidden;">
+            <div id="cycleBar" style="height:100%;background:var(--accent);transition:width 0.5s;width:0%;"></div>
+        </div>
+        <!-- Live log -->
+        <div id="cycleLog" style="margin-top:12px;max-height:200px;overflow-y:auto;font-family:var(--font-mono);font-size:0.8rem;color:var(--text-muted);display:none;">
+        </div>
+    </div>
+</div>
+
+<!-- Stats Grid -->
+<div class="stats-grid">
+    <div class="stat-card animate-fade-up delay-1">
+        <div class="stat-icon" style="background:rgba(193,205,125,0.12);color:var(--accent);">📊</div>
+        <div class="stat-value">{{ trend_count }}</div>
+        <div class="stat-label">Trends (7d)</div>
+    </div>
+    <div class="stat-card animate-fade-up delay-2">
+        <div class="stat-icon" style="background:rgba(96,165,250,0.12);color:var(--info);">👁</div>
+        <div class="stat-value">{{ competitor_count }}</div>
+        <div class="stat-label">Competitor Scans (7d)</div>
+    </div>
+    <div class="stat-card animate-fade-up delay-3">
+        <div class="stat-icon" style="background:rgba(74,222,128,0.12);color:var(--success);">📋</div>
+        <div class="stat-value">{{ recent_reports|length }}</div>
+        <div class="stat-label">Reports (7d)</div>
+    </div>
+    <div class="stat-card animate-fade-up delay-4">
+        <div class="stat-icon" style="background:rgba(251,191,36,0.12);color:var(--warning);">
+            {% if todays_plan %}✓{% else %}—{% endif %}
+        </div>
+        <div class="stat-value">{% if todays_plan %}Ready{% else %}None{% endif %}</div>
+        <div class="stat-label">Today's Plan</div>
+    </div>
+</div>
+
+<div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
+
+    <!-- Executive Summary -->
+    <div class="card animate-fade-up delay-5" style="grid-column:1/-1;">
+        <div class="card-header">
+            <h3>☀ Morning Briefing</h3>
+            {% if latest_report %}
+            <span style="font-size:0.8rem;color:var(--text-muted);">{{ latest_report.created_at.strftime('%b %d, %H:%M') }}</span>
+            {% endif %}
+        </div>
+        <div class="card-body">
+            {% if latest_report and latest_report.summary %}
+            <p style="line-height:1.7;color:var(--text-secondary);">{{ latest_report.summary }}</p>
+            {% else %}
+            <p style="color:var(--text-muted);">No morning report yet. Run a night cycle to generate one.</p>
+            {% endif %}
+        </div>
+    </div>
+
+    <!-- Content Plan -->
+    <div class="card animate-fade-up delay-6">
+        <div class="card-header">
+            <h3>📋 Content Plan</h3>
+            {% if tomorrows_plan %}
+            <span class="badge badge-{% if tomorrows_plan.status == 'approved' %}success{% elif tomorrows_plan.status == 'pending' %}warning{% else %}info{% endif %}">
+                {{ tomorrows_plan.status }}
+            </span>
+            {% endif %}
+        </div>
+        <div class="card-body">
+            {% set plan = tomorrows_plan or todays_plan %}
+            {% if plan %}
+            {% set plan_data = plan.plan_data | tojson | safe %}
+            <script>var _planData = {{ plan_data }}; try { _planData = JSON.parse(_planData); } catch(e) {}</script>
+            <div id="planContent">
+                <div style="margin-bottom:12px;">
+                    <div style="font-size:0.85rem;color:var(--text-muted);">Date: {{ plan.plan_date }}</div>
+                    <div style="font-weight:600;margin-top:4px;" id="planTheme"></div>
+                </div>
+                <div id="planItems" style="display:flex;flex-direction:column;gap:8px;"></div>
+                {% if plan.status == 'pending' %}
+                <button class="btn btn-primary btn-sm" style="margin-top:12px;" onclick="approvePlan('{{ plan.id }}')">
+                    ✓ Approve Plan
+                </button>
+                {% endif %}
+            </div>
+            {% else %}
+            <p style="color:var(--text-muted);">No content plan available. Run a night cycle to generate one.</p>
+            {% endif %}
+        </div>
+    </div>
+
+    <!-- Recent Reports -->
+    <div class="card animate-fade-up delay-7">
+        <div class="card-header">
+            <h3>📄 Recent Reports</h3>
+        </div>
+        <div class="card-body">
+            {% if recent_reports %}
+            <div style="display:flex;flex-direction:column;gap:8px;">
+                {% for report in recent_reports %}
+                <div style="padding:10px 12px;background:var(--bg-hover);border-radius:var(--radius-sm);cursor:pointer;"
+                     onclick="viewReport('{{ report.id }}')">
+                    <div style="display:flex;justify-content:space-between;align-items:center;">
+                        <div style="font-weight:500;">{{ report.report_type | capitalize }} Report</div>
+                        <span class="badge badge-{% if report.status == 'completed' %}success{% else %}danger{% endif %}">
+                            {{ report.status }}
+                        </span>
+                    </div>
+                    <div style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">
+                        {{ report.created_at.strftime('%b %d, %H:%M') }}
+                        {% if report.summary %}
+                        — {{ report.summary[:80] }}{% if report.summary|length > 80 %}...{% endif %}
+                        {% endif %}
+                    </div>
+                </div>
+                {% endfor %}
+            </div>
+            {% else %}
+            <p style="color:var(--text-muted);">No reports yet.</p>
+            {% endif %}
+        </div>
+    </div>
+
+    <!-- Trends Preview -->
+    <div class="card animate-fade-up delay-8">
+        <div class="card-header">
+            <h3>🔥 Latest Trends</h3>
+            <button class="btn btn-ghost btn-sm" onclick="loadTrends()">Refresh</button>
+        </div>
+        <div class="card-body" id="trendsContainer">
+            <p style="color:var(--text-muted);">Loading...</p>
+        </div>
+    </div>
+
+    <!-- Competitors Preview -->
+    <div class="card animate-fade-up delay-9">
+        <div class="card-header">
+            <h3>👁 Competitor Watch</h3>
+            <button class="btn btn-ghost btn-sm" onclick="loadCompetitors()">Refresh</button>
+        </div>
+        <div class="card-body" id="competitorsContainer">
+            <p style="color:var(--text-muted);">Loading...</p>
+        </div>
+    </div>
+
+</div>
+
+<!-- Report Detail Modal -->
+<div id="reportModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;padding:40px;overflow-y:auto;"
+     onclick="if(event.target===this)this.style.display='none'">
+    <div style="max-width:700px;margin:0 auto;background:var(--bg-white);border-radius:var(--radius-lg);padding:24px;border:1px solid var(--border);">
+        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
+            <h3 id="modalTitle">Report Details</h3>
+            <button class="btn btn-ghost btn-sm" onclick="document.getElementById('reportModal').style.display='none'">✕</button>
+        </div>
+        <div id="modalContent" style="font-family:var(--font-mono);font-size:0.85rem;white-space:pre-wrap;color:var(--text-secondary);max-height:60vh;overflow-y:auto;">
+        </div>
+    </div>
+</div>
+
+<style>
+@keyframes spin { to { transform: rotate(360deg); } }
+</style>
+
+<script>
+// ── Cycle Control ──
+let _pollInterval = null;
+
+function startCycle() {
+    const btn = document.getElementById('btnStartCycle');
+    btn.disabled = true;
+    btn.textContent = '⏳ Starting...';
+
+    fetch('/night-ops/api/start-cycle', { method: 'POST' })
+        .then(r => r.json())
+        .then(data => {
+            if (data.error) {
+                alert(data.error);
+                btn.disabled = false;
+                btn.textContent = '▶ Run Night Cycle';
+                return;
+            }
+            document.getElementById('cycleStatus').style.display = 'block';
+            document.getElementById('cycleLog').style.display = 'block';
+            _pollInterval = setInterval(pollStatus, 2000);
+        })
+        .catch(err => {
+            alert('Error: ' + err);
+            btn.disabled = false;
+            btn.textContent = '▶ Run Night Cycle';
+        });
+}
+
+function pollStatus() {
+    fetch('/night-ops/api/cycle-status')
+        .then(r => r.json())
+        .then(data => {
+            document.getElementById('cycleAgent').textContent = data.current_agent || data.status;
+            document.getElementById('cycleProgress').textContent = data.progress + '%';
+            document.getElementById('cycleBar').style.width = data.progress + '%';
+
+            // Update log
+            const logEl = document.getElementById('cycleLog');
+            if (data.log && data.log.length) {
+                logEl.innerHTML = data.log.map(l =>
+                    `<div><span style="color:var(--accent);">${l.time}</span> [${l.agent}] ${l.message}</div>`
+                ).join('');
+                logEl.scrollTop = logEl.scrollHeight;
+            }
+
+            if (!data.running) {
+                clearInterval(_pollInterval);
+                _pollInterval = null;
+                const btn = document.getElementById('btnStartCycle');
+                btn.disabled = false;
+                btn.textContent = '▶ Run Night Cycle';
+
+                const spinner = document.getElementById('cycleSpinner');
+                spinner.style.animation = 'none';
+                spinner.textContent = data.status === 'completed' ? '✓' : '⚠';
+                spinner.style.color = data.status === 'completed' ? 'var(--success)' : 'var(--warning)';
+
+                if (data.result && data.result.report_summary) {
+                    document.getElementById('cycleMessage').textContent = data.result.report_summary.slice(0, 120);
+                }
+
+                // Reload page after a short delay to show fresh data
+                setTimeout(() => location.reload(), 3000);
+            }
+        })
+        .catch(() => {});
+}
+
+// ── Content Plan Render ──
+if (typeof _planData !== 'undefined' && _planData) {
+    try {
+        const plan = typeof _planData === 'string' ? JSON.parse(_planData) : _planData;
+        const themeEl = document.getElementById('planTheme');
+        if (themeEl && plan.theme) themeEl.textContent = '🎯 ' + plan.theme;
+
+        const itemsEl = document.getElementById('planItems');
+        if (itemsEl && plan.content_items) {
+            itemsEl.innerHTML = plan.content_items.slice(0, 6).map(item => `
+                <div style="padding:8px 10px;background:var(--bg-subtle);border-radius:var(--radius-sm);display:flex;align-items:center;gap:8px;">
+                    <span class="badge badge-${item.priority === 'high' ? 'danger' : item.priority === 'medium' ? 'warning' : 'info'}" style="font-size:0.7rem;">
+                        ${item.priority || 'low'}
+                    </span>
+                    <span style="font-weight:500;">${item.type}</span>
+                    <span style="color:var(--text-muted);font-size:0.85rem;">— ${item.product || ''}</span>
+                    <span style="margin-left:auto;font-size:0.75rem;color:var(--text-muted);">${item.platform || ''}</span>
+                </div>
+            `).join('');
+        }
+    } catch(e) { console.error('Plan parse error:', e); }
+}
+
+function approvePlan(planId) {
+    fetch(`/night-ops/api/plan/${planId}/approve`, { method: 'POST' })
+        .then(r => r.json())
+        .then(data => {
+            if (data.status === 'approved') location.reload();
+        });
+}
+
+// ── Trends ──
+function loadTrends() {
+    fetch('/night-ops/api/trends?limit=10')
+        .then(r => r.json())
+        .then(trends => {
+            const el = document.getElementById('trendsContainer');
+            if (!trends.length) { el.innerHTML = '<p style="color:var(--text-muted);">No trends yet.</p>'; return; }
+            el.innerHTML = trends.slice(0, 8).map(t => {
+                const d = t.data || {};
+                const title = d.title || d.query || t.category || 'Unknown';
+                return `<div style="padding:6px 0;border-bottom:1px solid var(--border-light);display:flex;align-items:center;gap:8px;">
+                    <span style="font-size:0.75rem;padding:2px 6px;background:var(--bg-hover);border-radius:4px;">${t.source}</span>
+                    <span style="flex:1;font-size:0.9rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${title.slice(0,60)}</span>
+                    <span style="font-size:0.8rem;color:var(--accent);">${(t.score * 100).toFixed(0)}%</span>
+                </div>`;
+            }).join('');
+        })
+        .catch(() => {
+            document.getElementById('trendsContainer').innerHTML = '<p style="color:var(--text-muted);">Failed to load.</p>';
+        });
+}
+
+// ── Competitors ──
+function loadCompetitors() {
+    fetch('/night-ops/api/competitors')
+        .then(r => r.json())
+        .then(comps => {
+            const el = document.getElementById('competitorsContainer');
+            if (!comps.length) { el.innerHTML = '<p style="color:var(--text-muted);">No data yet.</p>'; return; }
+            el.innerHTML = comps.map(c => `
+                <div style="padding:8px 0;border-bottom:1px solid var(--border-light);display:flex;align-items:center;gap:10px;">
+                    <span style="font-size:0.75rem;padding:2px 6px;background:var(--bg-hover);border-radius:4px;">${c.platform}</span>
+                    <a href="${c.page_url}" target="_blank" style="font-weight:500;">@${c.handle}</a>
+                    <span style="margin-left:auto;font-size:0.85rem;color:var(--text-muted);">${(c.followers || 0).toLocaleString()} followers</span>
+                    <span style="font-size:0.8rem;color:var(--accent);">${c.engagement || 0}%</span>
+                </div>
+            `).join('');
+        })
+        .catch(() => {
+            document.getElementById('competitorsContainer').innerHTML = '<p style="color:var(--text-muted);">Failed to load.</p>';
+        });
+}
+
+// ── Report Modal ──
+function viewReport(id) {
+    fetch(`/night-ops/api/report/${id}`)
+        .then(r => r.json())
+        .then(data => {
+            document.getElementById('modalTitle').textContent = (data.type || 'Report').charAt(0).toUpperCase() + (data.type || '').slice(1) + ' Report';
+            document.getElementById('modalContent').textContent = JSON.stringify(data.data, null, 2);
+            document.getElementById('reportModal').style.display = 'block';
+        });
+}
+
+// ── Init ──
+document.addEventListener('DOMContentLoaded', () => {
+    loadTrends();
+    loadCompetitors();
+});
+</script>
+{% endblock %}
-- 
